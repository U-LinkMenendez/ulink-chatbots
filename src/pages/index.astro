---
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>U Link Chatbots — Automatiza WhatsApp, Facebook e Instagram</title>
    <meta name="description" content="Automatiza tu WhatsApp, Facebook e Instagram para que no pierdas más prospectos por falta de atención y sin contratar más personal. Agenda, reagenda y confirma desde el chat, con recordatorios y guardado en CRM/Sheets." />
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      /* Animaciones sutiles */
      @keyframes float { 0%,100%{ transform: translateY(0) } 50%{ transform: translateY(-6px) } }
      @keyframes fadeUp { from{ opacity:0; transform: translateY(8px) } to{ opacity:1; transform: translateY(0) } }
     .float { animation: float 6s ease-in-out infinite; }
     .fade-up { animation: fadeUp.6s ease-out both; }
     .delay-1 { animation-delay:.1s }.delay-2 { animation-delay:.2s }.delay-3 { animation-delay:.3s }
      /* Fondo con blobs */
     .blob { filter: blur(40px); opacity:.35 }
    </style>
  </head>
  <body class="antialiased text-slate-900 selection:bg-emerald-100">
    <!-- Decorative blobs -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full bg-emerald-200 blob"></div>
      <div class="absolute top-40 -right-24 w- h- rounded-full bg-emerald-100 blob"></div>
      <div class="absolute bottom-0 left-1/3 w-80 h-80 rounded-full bg-slate-200 blob"></div>
    </div>

    <!-- Navbar minimal -->
    <header class="sticky top-0 z-20 backdrop-blur supports-[backdrop-filter]:bg-white/60 border-b border-slate-100">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="#" class="font-extrabold tracking-tight">U Link Chatbots</a>
        <nav class="hidden md:flex items-center gap-6 text-sm text-slate-600">
          <a href="#como-funciona" class="hover:text-slate-900">Cómo funciona</a>
          <a href="#beneficios" class="hover:text-slate-900">Beneficios</a>
          <a href="#faq" class="hover:text-slate-900">FAQ</a>
        </nav>
        <a href="https://cal.com/tu-usuario" class="px-3 py-2 rounded-xl bg-emerald-500 text-white font-semibold shadow-sm hover:opacity-90">Agenda ahora mismo tu cita</a>
      </div>
    </header>

    <!-- Hero -->
    <section class="relative">
      <div class="max-w-6xl mx-auto px-6 pt-16 pb-10 md:pt-24 md:pb-16">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div>
            <span class="inline-block px-3 py-1 rounded-full border text-xs text-slate-600 fade-up">Atención 24/7 sin más personal</span>
            <h1 class="mt-4 text-4xl md:text-5xl font-extrabold leading-tight fade-up delay-1">
              Automatiza tu <span class="bg-clip-text text-transparent bg-gradient-to-r from-emerald-500 to-emerald-700">WhatsApp, Facebook e Instagram</span> para no perder prospectos — y sin contratar más personal.
            </h1>
            <p class="mt-5 text-lg text-slate-600 fade-up delay-2">
              Agenda, reagenda y confirma desde el chat con disponibilidad en tiempo real. Enviamos recordatorios y guardamos todo en tu CRM/Sheets.
            </p>
            <div class="mt-7 flex flex-wrap gap-3 fade-up delay-3">
              <a href="https://cal.com/tu-usuario" class="group px-5 py-3 rounded-xl bg-emerald-500 text-white font-semibold shadow hover:shadow-md transition">
                Agenda ahora mismo tu cita
                <span class="inline-block ml-1 translate-x-0 group-hover:translate-x-0.5 transition">→</span>
              </a>
              <a href="#como-funciona" class="px-5 py-3 rounded-xl border font-semibold hover:bg-white/60">Ver cómo funciona</a>
            </div>
            <p class="mt-3 text-sm text-slate-500 fade-up delay-3">Implementación en días, no semanas.</p>
          </div>

          <!-- Mockup chat con animación -->
          <div class="relative">
            <div class="absolute -inset-6 bg-gradient-to-tr from-emerald-100 to-white rounded- blur-xl -z-10"></div>
            <div class="rounded-[1.5rem] border bg-white/70 backdrop-blur shadow-xl p-4 md:p-6 float">
              <div class="flex items-center gap-3 border-b pb-3">
                <div class="w-9 h-9 rounded-full bg-emerald-500"></div>
                <div>
                  <p class="font-semibold leading-tight">U Link Bot</p>
                  <p class="text-xs text-slate-500">en línea</p>
                </div>
              </div>
              <div class="mt-4 space-y-3 text-sm">
                <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-slate-100 px-3 py-2">¡Hola! ¿Quieres agendar?</div>
                <div class="max-w-[80%] ml-auto rounded-2xl rounded-tr-sm bg-emerald-500 text-white px-3 py-2">Sí, mañana por la tarde</div>
                <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-slate-100 px-3 py-2">Tengo 4:30 y 6:00 p.m. ¿Cuál te sirve?</div>
                <div class="max-w-[80%] ml-auto rounded-2xl rounded-tr-sm bg-emerald-500 text-white px-3 py-2">6:00 p.m.</div>
                <div class="max-w-[80%] rounded-2xl rounded-tl-sm bg-slate-100 px-3 py-2">Listo ✅ Te envié recordatorio.</div>
              </div>
            </div>
            <!-- Badges -->
            <div class="absolute -bottom-4 -left-4 bg-white border rounded-xl px-3 py-2 shadow-sm text-xs text-slate-600">Disponibilidad en tiempo real</div>
            <div class="absolute -top-4 -right-4 bg-white border rounded-xl px-3 py-2 shadow-sm text-xs text-slate-600">Recordatorios automáticos</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Beneficios -->
    <section id="beneficios" class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="group p-6 rounded-2xl border bg-white/70 backdrop-blur hover:shadow-lg transition">
          <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-3">
            <!-- calendar icon -->
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-emerald-600"><path d="M7 2v3M17 2v3M3 9h18M5 7h14a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </div>
          <h3 class="font-bold text-xl">Disponibilidad en tiempo real</h3>
          <p class="mt-2 text-slate-

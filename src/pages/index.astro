---
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>U Link Chatbots — Automatiza WhatsApp, Facebook e Instagram</title>
    <meta name="description" content="Automatiza tu WhatsApp, Facebook e Instagram para que no pierdas más prospectos por falta de atención y sin contratar más personal. Agenda, reagenda y confirma desde el chat, con recordatorios y guardado en CRM/Sheets." />
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="antialiased text-slate-900">
    <!-- Hero -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-slate-50 to-white -z-10"></div>
      <div class="max-w-6xl mx-auto px-6 py-20">
        <div class="max-w-3xl">
          <p class="inline-block px-3 py-1 rounded-full border text-sm text-slate-600">U Link Chatbots</p>
          <h1 class="mt-4 text-4xl md:text-5xl font-extrabold leading-tight">
            Automatiza tu <span class="underline decoration-8 decoration-emerald-300">WhatsApp, Facebook e Instagram</span> para que no pierdas más prospectos por falta de atención — y sin contratar más personal.
          </h1>
          <p class="mt-5 text-lg text-slate-600">
            Agenda, reagenda y confirma desde el chat con disponibilidad en tiempo real. Enviamos recordatorios y guardamos todo en tu CRM/Sheets.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="https://cal.com/ulink/60min" class="px-5 py-3 rounded-xl bg-emerald-500 text-white font-semibold shadow hover:opacity-90">Agenda ahora mismo tu cita</a>
            <a href="#como-funciona" class="px-5 py-3 rounded-xl border font-semibold hover:bg-slate-50">Ver cómo funciona</a>
          </div>
          <p class="mt-3 text-sm text-slate-500">Implementación en días, no semanas.</p>
        </div>
      </div>
    </section>

    <!-- Beneficios -->
    <section class="max-w-6xl mx-auto px-6 py-14">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl border">
          <h3 class="font-bold text-xl">Disponibilidad en tiempo real</h3>
          <p class="mt-2 text-slate-600">Solo muestra huecos libres de tu Cal.com/Google Calendar.</p>
        </div>
        <div class="p-6 rounded-2xl border">
          <h3 class="font-bold text-xl">Reagenda y cancela en el chat</h3>
          <p class="mt-2 text-slate-600">El bot gestiona cambios sin que intervengas.</p>
        </div>
        <div class="p-6 rounded-2xl border">
          <h3 class="font-bold text-xl">Recordatorios + CRM</h3>
          <p class="mt-2 text-slate-600">Recordatorios automáticos y guardado en Sheets/CRM.</p>
        </div>
      </div>
    </section>

    <!-- Cómo funciona -->
    <section id="como-funciona" class="bg-slate-50 border-y">
      <div class="max-w-6xl mx-auto px-6 py-14">
        <h2 class="text-2xl font-bold">Cómo funciona</h2>
        <ol class="mt-6 grid md:grid-cols-3 gap-6 list-decimal list-inside">
          <li class="p-6 bg-white rounded-2xl border">El cliente escribe por WhatsApp, Facebook o Instagram.</li>
          <li class="p-6 bg-white rounded-2xl border">El bot consulta tu calendario y ofrece huecos.</li>
          <li class="p-6 bg-white rounded-2xl border">Confirmas y queda registrado (con recordatorio).</li>
        </ol>
      </div>
    </section>

    <!-- Prueba social / claims -->
    <section class="max-w-6xl mx-auto px-6 py-14">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-2xl border bg-white">
          <p class="text-lg">“Reduce no-shows y libera horas de recepción.”</p>
        </div>
        <div class="p-6 rounded-2xl border bg-white">
          <p class="text-lg">“Atiende 24/7 sin contratar más personal.”</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-slate-50 border-y">
      <div class="max-w-6xl mx-auto px-6 py-14">
        <h2 class="text-2xl font-bold">Preguntas frecuentes</h2>
        <div class="mt-6 grid md:grid-cols-3 gap-6">
          <div class="p-6 bg-white rounded-2xl border">
            <h3 class="font-semibold">¿Funciona con Google Calendar?</h3>
            <p class="mt-2 text-slate-600">Sí, vía Cal.com.</p>
          </div>
          <div class="p-6 bg-white rounded-2xl border">
            <h3 class="font-semibold">¿Puedo personalizar mensajes?</h3>
            <p class="mt-2 text-slate-600">Sí, tono y flujos.</p>
          </div>
          <div class="p-6 bg-white rounded-2xl border">
            <h3 class="font-semibold">¿Guarda los datos?</h3>
            <p class="mt-2 text-slate-600">Sí, en Sheets/CRM.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="max-w-6xl mx-auto px-6 py-16 text-center">
      <h2 class="text-3xl font-extrabold">¿Listo para no perder ni un prospecto más?</h2>
      <p class="mt-2 text-slate-600">Automatiza tu WhatsApp, Facebook e Instagram y agenda ahora mismo tu cita.</p>
      <a href="https://cal.com/ulink/60min" class="inline-block mt-6 px-6 py-3 rounded-xl bg-emerald-500 text-white font-semibold shadow hover:opacity-90">Agenda ahora mismo tu cita</a>
      <p class="mt-3 text-slate-500 text-sm">U Link Chatbots · Mérida, Yucatán</p>
    </section>
  </body>
</html>
